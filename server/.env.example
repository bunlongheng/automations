# YouTube Data API key (for checking liked videos playlist)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Claude API key (for AI processing)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port
PORT=3009

# Check interval in minutes (how often to check for new likes)
CHECK_INTERVAL_MIN=5

# YouTube channel ID (your channel)
YOUTUBE_CHANNEL_ID=your_channel_id_here

# Output: where to send results
# Options: stickies, file, notion
OUTPUT_MODE=stickies
STICKIES_URL=http://10.0.0.218:4444
